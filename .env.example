# API base URL (optional). Used when the api-server is not on the same origin.
# In dev, Vite proxies /api and /health to http://localhost:4000 (see vite.config.ts),
# so leave unset and run api-server (e.g. cd api-server && npm run dev) on port 4000.
# For production or a different API host, set for example:
# VITE_API_BASE_URL=http://localhost:4000
